# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/eshopzz
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eshopzz?retryWrites=true&w=majority

